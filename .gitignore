# Raw federal datasets (~7 GB) — fetch with download_town_data.py + the county data.
# Not in the repo; lives next to the scripts as civica_data/.
civica_data/

# Internal agency playbook (pricing, scripts, SOPs) — never publish.
for-agents/

# Internal monetization / business strategy — never publish.
niche-playbook/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Logs / scratch
*.log
_*.log
_*.py

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Civica Signals — local-only data (PDF archive + SQLite store + WAL sidecars).
# The schema is code (signals/db.py); the data is rebuildable from raw PDFs.
signals/raw/
signals/signals.db
signals/signals.db-wal
signals/signals.db-shm
signals/pipeline_run.log
# regenerated each link/resolve run (human-review scratch)
signals/link/ambiguous_links.txt
signals/enrich/ambiguous_entities.txt

# The "_*.py" scratch rule above also matches __init__.py — keep package markers.
!signals/**/__init__.py
